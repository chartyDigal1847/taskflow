APP_NAME=TaskFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://taskflow.deoris.test

# DEORIS Portal (sole identity provider — embeds this module via iframe)
APP_PORTAL_URL=https://deoris.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# TaskFlow-owned database only (no shared DEORIS user tables)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=deoris_taskflow
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Service identity (SOA)
TASKFLOW_SERVICE_KEY=taskflow-service
TASKFLOW_SERVICE_URL=https://taskflow.deoris.test
TASKFLOW_API_VERSION=v1
TASKFLOW_EVENT_SECRET=
