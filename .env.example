APP_NAME=TaskFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://taskflow.deoris.net

# DEORIS Portal (sole identity provider — embeds this module via iframe)
APP_PORTAL_URL=https://deoris.net
AUTH_SERVICE_URL=https://deoris.net
DEORIS_PORTAL_URL=https://deoris.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=warning

# TaskFlow-owned database only (no shared DEORIS user tables)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=deoris_taskflow
DB_USERNAME=taskflow
DB_PASSWORD=change-me-db-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.deoris.net
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=none

QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Service identity (SOA)
TASKFLOW_SERVICE_KEY=taskflow-service
TASKFLOW_SERVICE_URL=https://taskflow.deoris.net
TASKFLOW_API_VERSION=v1
TASKFLOW_EVENT_SECRET=change-me-taskflow
TASKFLOW_SEARCH_TOKEN=change-me-taskflow-search-token
